<Window x:Class="GamePrince.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Game Prince" Height="750" Width="1150"
        Background="#0f172a" WindowStartupLocation="CenterScreen"
        FontFamily="Segoe UI Semibold">
    
    <Window.Resources>
        <DropShadowEffect x:Key="cardShadow" BlurRadius="15" ShadowDepth="2" Opacity="0.3" Color="Black"/>
        
        <!-- Glassmorphism Styles -->
        <Style x:Key="GlassBorder" TargetType="Border">
            <Setter Property="Background" Value="#1e293b99"/> <!-- Low opacity background -->
            <Setter Property="BorderBrush" Value="#ffffff22"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="16"/>
        </Style>

        <Style x:Key="NavButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#94a3b8"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Padding" Value="15,10"/>
            <Setter Property="Margin" Value="0,5"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="8" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Left" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#334155"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                            <Trigger Property="Tag" Value="Active">
                                <Setter Property="Background" Value="#8b5cf6"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PremiumButtonStyle" TargetType="Button">
             <Setter Property="Background" Value="#8b5cf6"/>
             <Setter Property="Foreground" Value="White"/>
             <Setter Property="BorderThickness" Value="0"/>
             <Setter Property="Padding" Value="15,8"/>
             <Setter Property="Cursor" Value="Hand"/>
             <Setter Property="Template">
                 <Setter.Value>
                     <ControlTemplate TargetType="Button">
                         <Border Background="{TemplateBinding Background}" CornerRadius="10">
                             <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                         </Border>
                     </ControlTemplate>
                 </Setter.Value>
             </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="260"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Sidebar -->
        <Border Grid.Column="0" Background="#111827" BorderBrush="#1f2937" BorderThickness="0,0,1,0">
            <DockPanel LastChildFill="True">
                <StackPanel DockPanel.Dock="Top" Margin="30,40,30,40">
                    <TextBlock Text="GAME PRINCE" Foreground="#a78bfa" FontSize="22" FontWeight="ExtraBold">
                        <TextBlock.Effect>
                            <DropShadowEffect BlurRadius="10" Color="#8b5cf6" Opacity="0.5" ShadowDepth="0"/>
                        </TextBlock.Effect>
                    </TextBlock>
                    <TextBlock Text="DEV WORKSPACE" Foreground="#64748b" FontSize="10" FontWeight="Bold" Margin="0,5,0,0"/>
                </StackPanel>

                <StackPanel DockPanel.Dock="Bottom" Margin="20" VerticalAlignment="Bottom">
                    <Button Content="⚙ 设置" Style="{StaticResource NavButton}"/>
                    <Button Content="👤 个人中心" Style="{StaticResource NavButton}"/>
                </StackPanel>

                <StackPanel Margin="15,0">
                    <Button x:Name="NavProjectOverview" Content="📊 项目概览" Style="{StaticResource NavButton}" Click="ShowProjectOverview"/>
                    <Button x:Name="NavKanban" Content="📋 任务看板" Style="{StaticResource NavButton}" Click="ShowKanban"/>
                    <Button x:Name="NavPlan" Content="📅 开发计划" Style="{StaticResource NavButton}" Click="ShowPlan"/>
                    <Button x:Name="NavHeatmap" Content="🔥 活跃热力图" Style="{StaticResource NavButton}" Click="ShowHeatmap"/>
                    <Button x:Name="NavListView" Content="📝 任务列表" Style="{StaticResource NavButton}" Click="ShowListView"/>
                    <Button x:Name="NavCalendar" Content="🗓️ 日历视图" Style="{StaticResource NavButton}" Click="ShowCalendar"/>
                    <Button x:Name="NavWeeklyReport" Content="⏱️ 工时周报" Style="{StaticResource NavButton}" Click="ShowWeeklyReport"/>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- Main Content -->
        <Grid Grid.Column="1" Margin="40">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <DockPanel Grid.Row="0" Margin="0,0,0,30">
                <StackPanel>
                    <TextBlock x:Name="TitleText" Text="任务看板" Foreground="White" FontSize="32" FontWeight="Bold"/>
                    <TextBlock x:Name="ProjectNameText" Text="未选择项目" Foreground="#64748b" FontSize="14" Margin="0,5,0,0"/>
                </StackPanel>
                
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                    <!-- Search Box -->
                    <Border Background="#1e293b" CornerRadius="10" Margin="0,0,20,0" Padding="10,5">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="🔍" Foreground="#64748b" VerticalAlignment="Center" Margin="0,0,10,0"/>
                            <TextBox x:Name="SearchBox" Width="200" Background="Transparent" BorderThickness="0" Foreground="White" CaretBrush="White" VerticalAlignment="Center" TextChanged="SearchBox_TextChanged"/>
                        </StackPanel>
                    </Border>

                    <Button Content="选择项目" Click="SelectProject_Click" Style="{StaticResource PremiumButtonStyle}"/>
                    
                    <StackPanel Margin="20,0,0,0" VerticalAlignment="Center">
                        <TextBlock x:Name="StatsText" Text="提交总数: 0" Foreground="#94a3b8" FontSize="12"/>
                        <TextBlock x:Name="BranchText" Text="分支: -" Foreground="#06b6d4" FontSize="12" Margin="0,2,0,0"/>
                    </StackPanel>
                </StackPanel>
            </DockPanel>

            <!-- Project Overview View -->
            <Grid x:Name="ProjectOverviewView" Grid.Row="1" Visibility="Collapsed">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <!-- Summary Cards -->
                        <Grid Margin="0,0,0,30">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            
                            <Border Grid.Column="0" Style="{StaticResource GlassBorder}" Margin="0,0,10,0" Padding="20">
                                <StackPanel>
                                    <TextBlock Text="总任务" Foreground="#94a3b8" FontSize="12"/>
                                    <TextBlock x:Name="OverviewTotalTasks" Text="0" Foreground="White" FontSize="32" FontWeight="Bold"/>
                                </StackPanel>
                            </Border>
                            
                            <Border Grid.Column="1" Style="{StaticResource GlassBorder}" Margin="5,0,5,0" Padding="20">
                                <StackPanel>
                                    <TextBlock Text="进行中" Foreground="#94a3b8" FontSize="12"/>
                                    <TextBlock x:Name="OverviewInProgress" Text="0" Foreground="#f59e0b" FontSize="32" FontWeight="Bold"/>
                                </StackPanel>
                            </Border>
                            
                            <Border Grid.Column="2" Style="{StaticResource GlassBorder}" Margin="5,0,5,0" Padding="20">
                                <StackPanel>
                                    <TextBlock Text="已完成" Foreground="#94a3b8" FontSize="12"/>
                                    <TextBlock x:Name="OverviewCompleted" Text="0" Foreground="#10b981" FontSize="32" FontWeight="Bold"/>
                                </StackPanel>
                            </Border>
                            
                            <Border Grid.Column="3" Style="{StaticResource GlassBorder}" Margin="10,0,0,0" Padding="20">
                                <StackPanel>
                                    <TextBlock Text="里程碑" Foreground="#94a3b8" FontSize="12"/>
                                    <TextBlock x:Name="OverviewMilestones" Text="0" Foreground="#8b5cf6" FontSize="32" FontWeight="Bold"/>
                                </StackPanel>
                            </Border>
                        </Grid>
                        
                        <!-- Project Info -->
                        <Border Style="{StaticResource GlassBorder}" Padding="25" Margin="0,0,0,20">
                            <DockPanel>
                                <TextBlock Text="项目信息" Foreground="White" FontSize="18" FontWeight="Bold" DockPanel.Dock="Top" Margin="0,0,0,15"/>
                                <StackPanel>
                                    <TextBlock x:Name="OverviewProjectName" Text="未选择项目" Foreground="#a78bfa" FontSize="16" FontWeight="Bold"/>
                                    <TextBlock x:Name="OverviewProjectPath" Text="" Foreground="#64748b" FontSize="12" Margin="0,5,0,0"/>
                                    <TextBlock x:Name="OverviewGitStats" Text="Git提交: 0 | 分支: -" Foreground="#94a3b8" FontSize="12" Margin="0,10,0,0"/>
                                </StackPanel>
                            </DockPanel>
                        </Border>
                        
                        <!-- Recent Tasks -->
                        <Border Style="{StaticResource GlassBorder}" Padding="25" Margin="0,0,0,20">
                            <DockPanel>
                                <TextBlock Text="最近任务" Foreground="White" FontSize="18" FontWeight="Bold" DockPanel.Dock="Top" Margin="0,0,0,15"/>
                                <StackPanel x:Name="OverviewRecentTasks"/>
                            </DockPanel>
                        </Border>
                        
                        <!-- Upcoming Milestones -->
                        <Border Style="{StaticResource GlassBorder}" Padding="25">
                            <DockPanel>
                                <TextBlock Text="即将到期" Foreground="White" FontSize="18" FontWeight="Bold" DockPanel.Dock="Top" Margin="0,0,0,15"/>
                                <StackPanel x:Name="OverviewUpcomingMilestones"/>
                            </DockPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </Grid>
            
            <!-- Dashboard / Kanban View -->
            <Grid x:Name="KanbanView" Grid.Row="1" Visibility="Collapsed">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                
                <!-- Task Pool -->
                <Border Grid.Column="0" Style="{StaticResource GlassBorder}" Margin="0,0,10,0" Padding="20">
                    <DockPanel LastChildFill="True">
                        <DockPanel DockPanel.Dock="Top" Margin="0,0,0,20">
                            <TextBlock Text="任务池" Foreground="White" FontSize="18" FontWeight="Bold"/>
                            <Button Content="+" Click="AddTask_Click" HorizontalAlignment="Right" Background="Transparent" Foreground="#94a3b8" BorderThickness="0" FontSize="24" Cursor="Hand"/>
                        </DockPanel>
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <StackPanel x:Name="TaskPoolList"/>
                        </ScrollViewer>
                    </DockPanel>
                </Border>

                <!-- In Progress -->
                <Border Grid.Column="1" Style="{StaticResource GlassBorder}" Margin="5,0,5,0" Padding="20">
                    <DockPanel LastChildFill="True">
                        <TextBlock DockPanel.Dock="Top" Text="正在进行" Foreground="White" FontSize="18" FontWeight="Bold" Margin="0,0,0,20"/>
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <StackPanel x:Name="InProgressList"/>
                        </ScrollViewer>
                    </DockPanel>
                </Border>

                <!-- Completed -->
                <Border Grid.Column="2" Style="{StaticResource GlassBorder}" Margin="10,0,0,0" Padding="20">
                    <DockPanel LastChildFill="True">
                        <TextBlock DockPanel.Dock="Top" Text="已完成" Foreground="White" FontSize="18" FontWeight="Bold" Margin="0,0,0,20"/>
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <StackPanel x:Name="CompletedList"/>
                        </ScrollViewer>
                    </DockPanel>
                </Border>
            </Grid>
            
            <!-- Milestone View -->
            <Grid x:Name="MilestoneView" Grid.Row="1" Visibility="Collapsed">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel x:Name="MilestoneList" Margin="0,0,0,20"/>
                </ScrollViewer>
            </Grid>

            <!-- Heatmap View -->
            <Grid x:Name="HeatmapView" Grid.Row="1" Visibility="Collapsed">
                <Border Background="#1e293b" CornerRadius="20" Padding="30" Effect="{StaticResource cardShadow}" VerticalAlignment="Top">
                    <StackPanel>
                        <DockPanel Margin="0,0,0,20">
                            <TextBlock Text="项目开发活跃度 (过去 365 天)" Foreground="White" FontSize="18" FontWeight="Bold"/>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                                <TextBlock Text="Less" Foreground="#64748b" FontSize="10" Margin="0,0,5,0"/>
                                <Rectangle Width="10" Height="10" Fill="#1e293b" Margin="2,0"/>
                                <Rectangle Width="10" Height="10" Fill="#4c1d95" Margin="2,0"/>
                                <Rectangle Width="10" Height="10" Fill="#7c3aed" Margin="2,0"/>
                                <Rectangle Width="10" Height="10" Fill="#a78bfa" Margin="2,0"/>
                                <Rectangle Width="10" Height="10" Fill="#ddd6fe" Margin="2,0"/>
                                <TextBlock Text="More" Foreground="#64748b" FontSize="10" Margin="5,0,0,0"/>
                            </StackPanel>
                        </DockPanel>
                        
                        <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled">
                            <UniformGrid x:Name="HeatmapGrid" Rows="7" Columns="53" Height="140" Width="750" HorizontalAlignment="Left" VerticalAlignment="Top">
                                <!-- Generated by C# -->
                            </UniformGrid>
                        </ScrollViewer>
                        
                        <TextBlock x:Name="HeatmapTip" Text="提示：这是你在当前选定项目中的提交足迹。" Foreground="#64748b" FontSize="12" Margin="0,20,0,0" FontStyle="Italic"/>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- List View -->
            <Grid x:Name="TaskListViewGrid" Grid.Row="1" Visibility="Collapsed">
                <Border Background="#1e293b" CornerRadius="20" Padding="30" Effect="{StaticResource cardShadow}">
                    <DockPanel>
                        <DockPanel DockPanel.Dock="Top" Margin="0,0,0,20">
                            <TextBlock Text="任务列表" Foreground="White" FontSize="18" FontWeight="Bold"/>
                            <Button Content="+ 添加任务" Click="AddTask_Click" HorizontalAlignment="Right" Style="{StaticResource PremiumButtonStyle}"/>
                        </DockPanel>
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <StackPanel x:Name="TaskListContainer"/>
                        </ScrollViewer>
                    </DockPanel>
                </Border>
            </Grid>

            <!-- Calendar View -->
            <Grid x:Name="CalendarViewGrid" Grid.Row="1" Visibility="Collapsed">
                <Border Background="#1e293b" CornerRadius="20" Padding="30" Effect="{StaticResource cardShadow}">
                    <DockPanel>
                        <DockPanel DockPanel.Dock="Top" Margin="0,0,0,20">
                            <TextBlock Text="日历视图" Foreground="White" FontSize="18" FontWeight="Bold"/>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                <Button Content="◀" Click="PrevMonth" Background="Transparent" Foreground="White" BorderThickness="0" Padding="10,5" Cursor="Hand"/>
                                <TextBlock x:Name="CalendarMonthText" Text="" Foreground="White" FontSize="16" VerticalAlignment="Center" Margin="10,0"/>
                                <Button Content="▶" Click="NextMonth" Background="Transparent" Foreground="White" BorderThickness="0" Padding="10,5" Cursor="Hand"/>
                            </StackPanel>
                        </DockPanel>
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <StackPanel x:Name="CalendarContainer"/>
                        </ScrollViewer>
                    </DockPanel>
                </Border>
            </Grid>

            <!-- Weekly Report View -->
            <Grid x:Name="WeeklyReportViewGrid" Grid.Row="1" Visibility="Collapsed">
                <Border Background="#1e293b" CornerRadius="20" Padding="30" Effect="{StaticResource cardShadow}">
                    <StackPanel>
                        <TextBlock Text="个人工时周报" Foreground="White" FontSize="18" FontWeight="Bold" Margin="0,0,0,20"/>
                        <StackPanel x:Name="WeeklyReportContainer"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Grid>
    </Grid>
</Window>
