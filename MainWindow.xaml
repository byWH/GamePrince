<Window x:Class="GamePrince.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Game Prince" Height="750" Width="1200"
        Background="#0f172a" WindowStartupLocation="CenterScreen"
        FontFamily="Segoe UI">
    
    <Window.Resources>
        <!-- 扁平风格 - 无阴影效果 -->
        
        <!-- 卡片样式 (扁平风格) -->
        <Style x:Key="GlassBorder" TargetType="Border">
            <Setter Property="Background" Value="#1e293b"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="CornerRadius" Value="4"/>
            <Setter Property="Padding" Value="16"/>
        </Style>

        <!-- 任务卡片样式 (扁平风格) -->
        <Style x:Key="TaskCard" TargetType="Border">
            <Setter Property="Background" Value="#1e293b"/>
            <Setter Property="CornerRadius" Value="4"/>
            <Setter Property="Padding" Value="12"/>
            <Setter Property="Margin" Value="0,0,0,8"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#283548"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- 统计数字样式 -->
        <Style x:Key="StatNumber" TargetType="TextBlock">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="36"/>
            <Setter Property="FontWeight" Value="Bold"/>
        </Style>

        <!-- 统计标签样式 -->
        <Style x:Key="StatLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#94a3b8"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="Margin" Value="0,0,0,5"/>
        </Style>

        <!-- 搜索框样式 (扁平风格) -->
        <Style x:Key="SearchBoxStyle" TargetType="Border">
            <Setter Property="Background" Value="#1e293b"/>
            <Setter Property="CornerRadius" Value="4"/>
            <Setter Property="Padding" Value="12,8"/>
        </Style>

        <!-- 图标按钮样式 (扁平风格) -->
        <Style x:Key="IconButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#94a3b8"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="8"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}" 
                                CornerRadius="4" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#334155"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="ViewSwitcherRadioButton" TargetType="RadioButton">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="border" Background="Transparent" CornerRadius="4" Padding="12,6">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#3b82f6"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="IsChecked" Value="False"/>
                                    <Condition Property="IsMouseOver" Value="True"/>
                                </MultiTrigger.Conditions>
                                <Setter TargetName="border" Property="Background" Value="#334155"/>
                                <Setter Property="Foreground" Value="White"/>
                            </MultiTrigger>
                            <Trigger Property="IsChecked" Value="False">
                                <Setter Property="Foreground" Value="#94a3b8"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="280"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Sidebar -->
        <Border Grid.Column="0" Background="#111827">
            <DockPanel LastChildFill="True">
                <!-- Logo区域 -->
                <StackPanel DockPanel.Dock="Top" Margin="25,35,25,35">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="GAME" Foreground="White" FontSize="24" FontWeight="ExtraBold"/>
                        <TextBlock Text=" PRINCE" Foreground="#8b5cf6" FontSize="24" FontWeight="ExtraBold"/>
                    </StackPanel>
                    <TextBlock Text="DEV WORKSPACE" Foreground="#475569" FontSize="10" FontWeight="Bold" Margin="0,6,0,0"/>
                </StackPanel>

                <!-- 底部设置区域 -->
                <StackPanel DockPanel.Dock="Bottom" Margin="20,0,20,20" VerticalAlignment="Bottom">
                    <Border Height="1" Background="#1e293b" Margin="0,0,0,15"/>
                    <Button Content="⚙  设置" Style="{StaticResource NavButtonStyle}"/>
                    <Button Content="👤 个人中心" Style="{StaticResource NavButtonStyle}"/>
                </StackPanel>

                <!-- 主导航 -->
                <ScrollViewer VerticalScrollBarVisibility="Auto" Margin="15,0">
                    <StackPanel>
                        <TextBlock Text="导航" Foreground="#475569" FontSize="11" FontWeight="SemiBold" Margin="15,10,0,10"/>
                        <Button x:Name="NavProjectOverview" Content="📊 项目概览" Style="{StaticResource NavButtonStyle}" Click="ShowProjectOverview"/>
                        <Button x:Name="NavTasks" Content="📋 任务管理" Style="{StaticResource NavButtonStyle}" Click="ShowTaskManagement"/>
                        <Button x:Name="NavPlan" Content="📅 开发计划" Style="{StaticResource NavButtonStyle}" Click="ShowPlan"/>
                        <Button x:Name="NavHeatmap" Content="🔥 活跃热力图" Style="{StaticResource NavButtonStyle}" Click="ShowHeatmap"/>
                        <Button x:Name="NavResources" Content="📁 资源浏览器" Style="{StaticResource NavButtonStyle}" Click="ShowResources"/>
                        <Button x:Name="NavCalendar" Content="🗓️ 日历视图" Style="{StaticResource NavButtonStyle}" Click="ShowCalendar"/>
                        <Button x:Name="NavWeeklyReport" Content="⏱️ 工时周报" Style="{StaticResource NavButtonStyle}" Click="ShowWeeklyReport"/>
                        <Button x:Name="NavGitDiff" Content="🔀 版本对比" Style="{StaticResource NavButtonStyle}" Click="ShowGitDiff"/>
                        <Button x:Name="NavReleases" Content="🚀 发布管理" Style="{StaticResource NavButtonStyle}" Click="ShowReleases"/>
                        <Button x:Name="NavPlugins" Content="🔌 插件管理" Style="{StaticResource NavButtonStyle}" Click="ShowPlugins"/>
                    </StackPanel>
                </ScrollViewer>
            </DockPanel>
        </Border>

        <!-- Main Content -->
        <Grid Grid.Column="1" Margin="35">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- 顶部标题栏 -->
            <DockPanel Grid.Row="0" Margin="0,0,0,30">
                <StackPanel>
                    <TextBlock x:Name="TitleText" Text="任务看板" Foreground="White" FontSize="28" FontWeight="Bold"/>
                    <TextBlock x:Name="ProjectNameText" Text="未选择项目" Foreground="#64748b" FontSize="14" Margin="0,6,0,0"/>
                </StackPanel>
                
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                    <!-- 搜索框 -->
                    <Border Style="{StaticResource SearchBoxStyle}" Margin="0,0,20,0">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="🔍" Foreground="#64748b" VerticalAlignment="Center" Margin="0,0,10,0" FontSize="14"/>
                            <TextBox x:Name="SearchBox" Width="220" Background="Transparent" BorderThickness="0" 
                                     Foreground="White" CaretBrush="White" VerticalAlignment="Center" 
                                     TextChanged="SearchBox_TextChanged" FontSize="14"/>
                        </StackPanel>
                    </Border>

                    <!-- 里程碑过滤 -->
                    <Border Style="{StaticResource SearchBoxStyle}" Margin="0,0,20,0">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="🎯" Foreground="#64748b" VerticalAlignment="Center" Margin="0,0,10,0" FontSize="14"/>
                            <ComboBox x:Name="MilestoneFilter" Width="150" Background="Transparent" BorderThickness="0" 
                                      Foreground="White" VerticalAlignment="Center" 
                                      SelectedValuePath="Id"
                                      SelectionChanged="MilestoneFilter_SelectionChanged"
                                      Style="{StaticResource ModernComboBoxStyle}">
                                <ComboBox.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding Title}" Foreground="White"/>
                                    </DataTemplate>
                                </ComboBox.ItemTemplate>
                            </ComboBox>
                        </StackPanel>
                    </Border>

                    <!-- 视图切换 -->
                    <Border x:Name="TaskViewSwitcher" Background="#1e293b" CornerRadius="4" Margin="0,0,20,0" Padding="2" Visibility="Collapsed">
                        <StackPanel Orientation="Horizontal">
                            <RadioButton x:Name="KanbanViewButton" Content="看板视图" Style="{StaticResource ViewSwitcherRadioButton}" IsChecked="True" Click="SwitchToKanbanView"/>
                            <RadioButton x:Name="ListViewButton" Content="列表视图" Style="{StaticResource ViewSwitcherRadioButton}" Click="SwitchToListView"/>
                        </StackPanel>
                    </Border>

                    <Button Content="选择项目" Click="SelectProject_Click" Style="{StaticResource PrimaryButtonStyle}"/>
                    
                    <!-- Git统计 -->
                    <StackPanel Margin="25,0,0,0" VerticalAlignment="Center">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="📂" Foreground="#64748b" FontSize="12" Margin="0,0,6,0"/>
                            <TextBlock x:Name="BranchText" Text="分支: -" Foreground="#06b6d4" FontSize="12"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                            <TextBlock Text="📜" Foreground="#64748b" FontSize="12" Margin="0,0,6,0"/>
                            <TextBlock x:Name="StatsText" Text="提交: 0" Foreground="#94a3b8" FontSize="12"/>
                        </StackPanel>
                    </StackPanel>
                </StackPanel>
            </DockPanel>

            <!-- Project Overview View -->
            <Grid x:Name="ProjectOverviewView" Grid.Row="1" Visibility="Collapsed">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <!-- 统计卡片 -->
                        <Grid Margin="0,0,0,25">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            
                            <Border Grid.Column="0" Style="{StaticResource GlassBorder}" Margin="0,0,8,0">
                                <StackPanel>
                                    <TextBlock Text="总任务" Style="{StaticResource StatLabel}"/>
                                    <TextBlock x:Name="OverviewTotalTasks" Text="0" Style="{StaticResource StatNumber}"/>
                                    <TextBlock Text="↑ 全部任务" Foreground="#475569" FontSize="11" Margin="0,8,0,0"/>
                                </StackPanel>
                            </Border>
                            
                            <Border Grid.Column="1" Style="{StaticResource GlassBorder}" Margin="4,0,4,0">
                                <StackPanel>
                                    <TextBlock Text="进行中" Style="{StaticResource StatLabel}"/>
                                    <TextBlock x:Name="OverviewInProgress" Text="0" Style="{StaticResource StatNumber}" Foreground="#f59e0b"/>
                                    <TextBlock Text="↻ 进行中" Foreground="#475569" FontSize="11" Margin="0,8,0,0"/>
                                </StackPanel>
                            </Border>
                            
                            <Border Grid.Column="2" Style="{StaticResource GlassBorder}" Margin="4,0,4,0">
                                <StackPanel>
                                    <TextBlock Text="已完成" Style="{StaticResource StatLabel}"/>
                                    <TextBlock x:Name="OverviewCompleted" Text="0" Style="{StaticResource StatNumber}" Foreground="#10b981"/>
                                    <TextBlock Text="✓ 已完成" Foreground="#475569" FontSize="11" Margin="0,8,0,0"/>
                                </StackPanel>
                            </Border>
                            
                            <Border Grid.Column="3" Style="{StaticResource GlassBorder}" Margin="8,0,0,0">
                                <StackPanel>
                                    <TextBlock Text="里程碑" Style="{StaticResource StatLabel}"/>
                                    <TextBlock x:Name="OverviewMilestones" Text="0" Style="{StaticResource StatNumber}" Foreground="#8b5cf6"/>
                                    <TextBlock Text="🎯 里程碑" Foreground="#475569" FontSize="11" Margin="0,8,0,0"/>
                                </StackPanel>
                            </Border>
                        </Grid>
                        
                        <!-- 项目信息 -->
                        <Border Style="{StaticResource GlassBorder}" Margin="0,0,0,20">
                            <DockPanel>
                                <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,20">
                                    <TextBlock Text="📁" Foreground="#8b5cf6" FontSize="20" Margin="0,0,10,0"/>
                                    <TextBlock Text="项目信息" Foreground="White" FontSize="18" FontWeight="SemiBold"/>
                                </StackPanel>
                                <StackPanel>
                                    <TextBlock x:Name="OverviewProjectName" Text="未选择项目" Foreground="#a78bfa" FontSize="16" FontWeight="Bold"/>
                                    <TextBlock x:Name="OverviewProjectPath" Text="" Foreground="#64748b" FontSize="12" Margin="0,8,0,0"/>
                                    <StackPanel Orientation="Horizontal" Margin="0,12,0,0">
                                        <Border Background="#1e293b" CornerRadius="6" Padding="10,6" Margin="0,0,10,0">
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="git" Foreground="#f05032" FontWeight="Bold" FontSize="12"/>
                                                <TextBlock x:Name="OverviewGitStats" Text=" 0 commits" Foreground="#94a3b8" FontSize="12" Margin="5,0,0,0"/>
                                            </StackPanel>
                                        </Border>
                                        <Border Background="#1e293b" CornerRadius="6" Padding="10,6">
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="🌿" Foreground="#06b6d4" FontSize="12"/>
                                                <TextBlock x:Name="OverviewBranchDisplay" Text=" -" Foreground="#06b6d4" FontSize="12" Margin="5,0,0,0"/>
                                            </StackPanel>
                                        </Border>
                                    </StackPanel>
                                </StackPanel>
                            </DockPanel>
                        </Border>
                        
                        <!-- 最近任务 -->
                        <Border Style="{StaticResource GlassBorder}" Margin="0,0,0,20">
                            <DockPanel>
                                <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,20">
                                    <TextBlock Text="📋" Foreground="#8b5cf6" FontSize="20" Margin="0,0,10,0"/>
                                    <TextBlock Text="最近任务" Foreground="White" FontSize="18" FontWeight="SemiBold"/>
                                </StackPanel>
                                <StackPanel x:Name="OverviewRecentTasks"/>
                            </DockPanel>
                        </Border>
                        
                        <!-- 即将到期 -->
                        <Border Style="{StaticResource GlassBorder}">
                            <DockPanel>
                                <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,20">
                                    <TextBlock Text="⏰" Foreground="#f59e0b" FontSize="20" Margin="0,0,10,0"/>
                                    <TextBlock Text="即将到期" Foreground="White" FontSize="18" FontWeight="SemiBold"/>
                                </StackPanel>
                                <StackPanel x:Name="OverviewUpcomingMilestones"/>
                            </DockPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </Grid>
            
            <!-- Task Management View (Unified Kanban and List) -->
            <Grid x:Name="TaskManagementView" Grid.Row="1" Visibility="Collapsed">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Kanban View -->
                <Grid x:Name="KanbanView" Visibility="Visible">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    
                    <!-- 任务池 -->
                    <Border Grid.Column="0" Style="{StaticResource GlassBorder}" Margin="0,0,8,0">
                        <DockPanel LastChildFill="True">
                            <DockPanel DockPanel.Dock="Top" Margin="0,0,0,20">
                                <StackPanel Orientation="Horizontal">
                                    <Border Background="#6366f1" CornerRadius="6" Width="8" Height="8" Margin="0,0,10,0" VerticalAlignment="Center"/>
                                    <TextBlock Text="任务池" Foreground="White" FontSize="16" FontWeight="SemiBold"/>
                                </StackPanel>
                                <Button Content="+" Click="AddTask_Click" HorizontalAlignment="Right" Style="{StaticResource IconButton}" FontSize="20" FontWeight="Bold"/>
                            </DockPanel>
                            <ScrollViewer VerticalScrollBarVisibility="Auto">
                                <StackPanel x:Name="TaskPoolList"/>
                            </ScrollViewer>
                        </DockPanel>
                    </Border>

                    <!-- 进行中 -->
                    <Border Grid.Column="1" Style="{StaticResource GlassBorder}" Margin="4,0,4,0">
                        <DockPanel LastChildFill="True">
                            <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,20">
                                <Border Background="#f59e0b" CornerRadius="6" Width="8" Height="8" Margin="0,0,10,0" VerticalAlignment="Center"/>
                                <TextBlock Text="正在进行" Foreground="White" FontSize="16" FontWeight="SemiBold"/>
                            </StackPanel>
                            <ScrollViewer VerticalScrollBarVisibility="Auto">
                                <StackPanel x:Name="InProgressList"/>
                            </ScrollViewer>
                        </DockPanel>
                    </Border>

                    <!-- 已完成 -->
                    <Border Grid.Column="2" Style="{StaticResource GlassBorder}" Margin="8,0,0,0">
                        <DockPanel LastChildFill="True">
                            <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,20">
                                <Border Background="#10b981" CornerRadius="6" Width="8" Height="8" Margin="0,0,10,0" VerticalAlignment="Center"/>
                                <TextBlock Text="已完成" Foreground="White" FontSize="16" FontWeight="SemiBold"/>
                            </StackPanel>
                            <ScrollViewer VerticalScrollBarVisibility="Auto">
                                <StackPanel x:Name="CompletedList"/>
                            </ScrollViewer>
                        </DockPanel>
                    </Border>
                </Grid>

                <!-- List View (Inside the same container for easier switching) -->
                <Grid x:Name="TaskListViewGrid" Visibility="Collapsed">
                    <Border Style="{StaticResource GlassBorder}">
                        <DockPanel>
                            <DockPanel DockPanel.Dock="Top" Margin="0,0,0,25">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="📝" Foreground="#8b5cf6" FontSize="20" Margin="0,0,10,0"/>
                                    <TextBlock Text="任务列表" Foreground="White" FontSize="18" FontWeight="SemiBold"/>
                                </StackPanel>
                                <Button Content="+ 添加任务" Click="AddTask_Click" HorizontalAlignment="Right" Style="{StaticResource PrimaryButtonStyle}"/>
                            </DockPanel>
                            <ScrollViewer VerticalScrollBarVisibility="Auto">
                                <StackPanel x:Name="TaskListContainer"/>
                            </ScrollViewer>
                        </DockPanel>
                    </Border>
                </Grid>
            </Grid>
            
            <!-- Milestone View -->
            <Grid x:Name="MilestoneView" Grid.Row="1" Visibility="Collapsed">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel x:Name="MilestoneList" Margin="0,0,0,20"/>
                </ScrollViewer>
            </Grid>

            <!-- Heatmap View -->
            <Grid x:Name="HeatmapView" Grid.Row="1" Visibility="Collapsed">
                <Border Style="{StaticResource GlassBorder}" VerticalAlignment="Top">
                    <StackPanel>
                        <DockPanel Margin="0,0,0,25">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="🔥" Foreground="#f59e0b" FontSize="20" Margin="0,0,10,0"/>
                                <TextBlock Text="项目开发活跃度" Foreground="White" FontSize="18" FontWeight="SemiBold"/>
                                <TextBlock Text=" (过去 365 天)" Foreground="#64748b" FontSize="14" VerticalAlignment="Bottom" Margin="5,0,0,2"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                                <TextBlock Text="Less" Foreground="#64748b" FontSize="11" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                <Rectangle Width="12" Height="12" Fill="#1e293b" Margin="2,0" RadiusX="2" RadiusY="2"/>
                                <Rectangle Width="12" Height="12" Fill="#4c1d95" Margin="2,0" RadiusX="2" RadiusY="2"/>
                                <Rectangle Width="12" Height="12" Fill="#7c3aed" Margin="2,0" RadiusX="2" RadiusY="2"/>
                                <Rectangle Width="12" Height="12" Fill="#a78bfa" Margin="2,0" RadiusX="2" RadiusY="2"/>
                                <Rectangle Width="12" Height="12" Fill="#ddd6fe" Margin="2,0" RadiusX="2" RadiusY="2"/>
                                <TextBlock Text="More" Foreground="#64748b" FontSize="11" Margin="8,0,0,0" VerticalAlignment="Center"/>
                            </StackPanel>
                        </DockPanel>
                        
                        <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled">
                            <UniformGrid x:Name="HeatmapGrid" Rows="7" Columns="53" Height="140" Width="750" HorizontalAlignment="Left" VerticalAlignment="Top">
                                <!-- Generated by C# -->
                            </UniformGrid>
                        </ScrollViewer>
                        
                        <TextBlock x:Name="HeatmapTip" Text="提示：这是你在当前选定项目中的提交足迹。" Foreground="#475569" FontSize="12" Margin="0,20,0,0" FontStyle="Italic"/>
                    </StackPanel>
                </Border>
            </Grid>



            <!-- Calendar View -->
            <Grid x:Name="CalendarViewGrid" Grid.Row="1" Visibility="Collapsed">
                <Border Style="{StaticResource GlassBorder}">
                    <DockPanel>
                        <DockPanel DockPanel.Dock="Top" Margin="0,0,0,25">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="🗓️" Foreground="#8b5cf6" FontSize="20" Margin="0,0,10,0"/>
                                <TextBlock Text="日历视图" Foreground="White" FontSize="18" FontWeight="SemiBold"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                <Button Content="◀" Click="PrevMonth" Style="{StaticResource IconButton}" FontSize="18"/>
                                <TextBlock x:Name="CalendarMonthText" Text="" Foreground="White" FontSize="16" VerticalAlignment="Center" Margin="15,0"/>
                                <Button Content="▶" Click="NextMonth" Style="{StaticResource IconButton}" FontSize="18"/>
                            </StackPanel>
                        </DockPanel>
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <StackPanel x:Name="CalendarContainer"/>
                        </ScrollViewer>
                    </DockPanel>
                </Border>
            </Grid>

            <!-- Weekly Report View -->
            <Grid x:Name="WeeklyReportViewGrid" Grid.Row="1" Visibility="Collapsed">
                <Border Style="{StaticResource GlassBorder}">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,25">
                            <TextBlock Text="⏱️" Foreground="#8b5cf6" FontSize="20" Margin="0,0,10,0"/>
                            <TextBlock Text="个人工时周报" Foreground="White" FontSize="18" FontWeight="SemiBold"/>
                        </StackPanel>
                        <StackPanel x:Name="WeeklyReportContainer"/>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- Git Diff/Compare View -->
            <Grid x:Name="GitDiffViewGrid" Grid.Row="1" Visibility="Collapsed">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="350"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                
                <!-- Left: Branch/Commit Selection -->
                <Border Grid.Column="0" Style="{StaticResource GlassBorder}" Margin="0,0,10,0">
                    <DockPanel>
                        <DockPanel DockPanel.Dock="Top" Margin="0,0,0,20">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="🔀" Foreground="#8b5cf6" FontSize="20" Margin="0,0,10,0"/>
                                <TextBlock Text="版本对比" Foreground="White" FontSize="18" FontWeight="SemiBold"/>
                            </StackPanel>
                            <Button Content="🔄" Click="RefreshGitDiff" HorizontalAlignment="Right" Style="{StaticResource IconButton}" ToolTip="刷新"/>
                        </DockPanel>
                        
                        <!-- Compare Controls -->
                        <StackPanel>
                            <TextBlock Text="源分支/提交" Foreground="#64748b" FontSize="12" Margin="0,0,0,8"/>
                            <ComboBox x:Name="FromBranchCombo" Width="300" Margin="0,0,0,20" Background="#1e293b" Foreground="White"/>
                            
                            <TextBlock Text="目标分支/提交" Foreground="#64748b" FontSize="12" Margin="0,0,0,8"/>
                            <ComboBox x:Name="ToBranchCombo" Width="300" Margin="0,0,0,20" Background="#1e293b" Foreground="White"/>
                            
                            <Button Content="🔍 开始对比" Click="CompareCommits" Style="{StaticResource PrimaryButtonStyle}" Margin="0,10,0,0"/>
                            
                            <Border Height="1" Background="#1e293b" Margin="0,25,0,25"/>
                            
                            <!-- Branch List -->
                            <TextBlock Text="可用分支" Foreground="#64748b" FontSize="12" Margin="0,0,0,10"/>
                            <ScrollViewer MaxHeight="300" VerticalScrollBarVisibility="Auto">
                                <StackPanel x:Name="BranchListContainer"/>
                            </ScrollViewer>
                        </StackPanel>
                    </DockPanel>
                </Border>
                
                <!-- Right: Diff Results -->
                <Border Grid.Column="1" Style="{StaticResource GlassBorder}">
                    <DockPanel>
                        <DockPanel DockPanel.Dock="Top" Margin="0,0,0,20">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="📊" Foreground="#8b5cf6" FontSize="20" Margin="0,0,10,0"/>
                                <TextBlock Text="对比结果" Foreground="White" FontSize="18" FontWeight="SemiBold"/>
                            </StackPanel>
                            <StackPanel x:Name="DiffStatsPanel" Orientation="Horizontal" HorizontalAlignment="Right" Visibility="Collapsed">
                                <Border Background="#10b981" CornerRadius="4" Padding="8,4" Margin="0,0,10,0">
                                    <TextBlock x:Name="DiffAdditionsText" Text="+0" Foreground="White" FontSize="12"/>
                                </Border>
                                <Border Background="#ef4444" CornerRadius="4" Padding="8,4">
                                    <TextBlock x:Name="DiffDeletionsText" Text="-0" Foreground="White" FontSize="12"/>
                                </Border>
                            </StackPanel>
                        </DockPanel>
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <StackPanel x:Name="DiffResultsContainer"/>
                        </ScrollViewer>
                    </DockPanel>
                </Border>
            </Grid>

            <!-- Releases Management View -->
            <Grid x:Name="ReleasesViewGrid" Grid.Row="1" Visibility="Collapsed">
                <Border Style="{StaticResource GlassBorder}">
                    <DockPanel>
                        <DockPanel DockPanel.Dock="Top" Margin="0,0,0,25">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="🚀" Foreground="#8b5cf6" FontSize="20" Margin="0,0,10,0"/>
                                <TextBlock Text="发布管理" Foreground="White" FontSize="18" FontWeight="SemiBold"/>
                            </StackPanel>
                            <Button Content="+ 新建版本" Click="AddRelease_Click" HorizontalAlignment="Right" Style="{StaticResource PrimaryButtonStyle}"/>
                        </DockPanel>
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <StackPanel x:Name="ReleasesContainer"/>
                        </ScrollViewer>
                    </DockPanel>
                </Border>
            </Grid>

            <!-- Resources Browser View -->
            <Grid x:Name="ResourcesViewGrid" Grid.Row="1" Visibility="Collapsed">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="350"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                
                <!-- Left: Project Tree -->
                <Border Grid.Column="0" Style="{StaticResource GlassBorder}" Margin="0,0,10,0">
                    <DockPanel>
                        <DockPanel DockPanel.Dock="Top" Margin="0,0,0,15">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="📁" Foreground="#8b5cf6" FontSize="20" Margin="0,0,10,0"/>
                                <TextBlock Text="项目结构" Foreground="White" FontSize="18" FontWeight="SemiBold"/>
                            </StackPanel>
                            <Button Content="🔄" Click="RefreshResourceTree" HorizontalAlignment="Right" Style="{StaticResource IconButton}" ToolTip="刷新"/>
                        </DockPanel>
                        <ScrollViewer VerticalScrollBarVisibility="Auto" x:Name="ProjectTreeScroll">
                            <StackPanel x:Name="ProjectTreeContainer"/>
                        </ScrollViewer>
                    </DockPanel>
                </Border>
                
                <!-- Right: Resource Stats & Details -->
                <Grid Grid.Column="1">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    
                    <!-- Resource Stats Cards -->
                    <Grid Grid.Row="0" Margin="0,0,0,15">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        
                        <Border Grid.Column="0" Style="{StaticResource GlassBorder}" Margin="0,0,5,0">
                            <StackPanel>
                                <TextBlock Text="📜" Foreground="#06b6d4" FontSize="16" Margin="0,0,0,5"/>
                                <TextBlock x:Name="StatScripts" Text="0" Foreground="White" FontSize="24" FontWeight="Bold"/>
                                <TextBlock Text="脚本 (.gd)" Foreground="#64748b" FontSize="11"/>
                            </StackPanel>
                        </Border>
                        
                        <Border Grid.Column="1" Style="{StaticResource GlassBorder}" Margin="5,0,5,0">
                            <StackPanel>
                                <TextBlock Text="🎬" Foreground="#f59e0b" FontSize="16" Margin="0,0,0,5"/>
                                <TextBlock x:Name="StatScenes" Text="0" Foreground="White" FontSize="24" FontWeight="Bold"/>
                                <TextBlock Text="场景 (.tscn)" Foreground="#64748b" FontSize="11"/>
                            </StackPanel>
                        </Border>
                        
                        <Border Grid.Column="2" Style="{StaticResource GlassBorder}" Margin="5,0,5,0">
                            <StackPanel>
                                <TextBlock Text="🖼️" Foreground="#10b981" FontSize="16" Margin="0,0,0,5"/>
                                <TextBlock x:Name="StatTextures" Text="0" Foreground="White" FontSize="24" FontWeight="Bold"/>
                                <TextBlock Text="纹理" Foreground="#64748b" FontSize="11"/>
                            </StackPanel>
                        </Border>
                        
                        <Border Grid.Column="3" Style="{StaticResource GlassBorder}" Margin="5,0,0,0">
                            <StackPanel>
                                <TextBlock Text="🎵" Foreground="#8b5cf6" FontSize="16" Margin="0,0,0,5"/>
                                <TextBlock x:Name="StatAudio" Text="0" Foreground="White" FontSize="24" FontWeight="Bold"/>
                                <TextBlock Text="音频" Foreground="#64748b" FontSize="11"/>
                            </StackPanel>
                        </Border>
                    </Grid>
                    
                    <!-- Godot Project Info & Detailed Stats -->
                    <Grid Grid.Row="1">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        
                        <!-- Godot Project Info Banner -->
                        <Border Grid.Row="0" x:Name="GodotProjectBanner" Style="{StaticResource GlassBorder}" Margin="0,0,0,15" Visibility="Collapsed">
                            <DockPanel>
                                <StackPanel DockPanel.Dock="Left" Orientation="Horizontal">
                                    <TextBlock Text="🎮" Foreground="#478cbf" FontSize="24" Margin="0,0,15,0" VerticalAlignment="Center"/>
                                    <StackPanel>
                                        <TextBlock x:Name="GodotProjectName" Text="Godot 项目" Foreground="White" FontSize="18" FontWeight="Bold"/>
                                        <TextBlock x:Name="GodotProjectPath" Text="" Foreground="#64748b" FontSize="12"/>
                                    </StackPanel>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                                    <Border Background="#1e3a5f" CornerRadius="4" Padding="10,5" Margin="0,0,10,0">
                                        <TextBlock x:Name="GodotMainScene" Text="主场景: -" Foreground="#06b6d4" FontSize="12"/>
                                    </Border>
                                    <Border Background="#1e3a5f" CornerRadius="4" Padding="10,5">
                                        <TextBlock x:Name="GodotTotalResources" Text="总资源: 0" Foreground="#10b981" FontSize="12"/>
                                    </Border>
                                </StackPanel>
                            </DockPanel>
                        </Border>
                        
                        <!-- Detailed Resource List -->
                        <Border Grid.Row="1" Style="{StaticResource GlassBorder}">
                            <DockPanel>
                                <DockPanel DockPanel.Dock="Top" Margin="0,0,0,15">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="📊" Foreground="#8b5cf6" FontSize="20" Margin="0,0,10,0"/>
                                        <TextBlock Text="资源详情" Foreground="White" FontSize="18" FontWeight="SemiBold"/>
                                    </StackPanel>
                                </DockPanel>
                                <ScrollViewer VerticalScrollBarVisibility="Auto">
                                    <StackPanel x:Name="ResourceDetailsContainer"/>
                                </ScrollViewer>
                            </DockPanel>
                        </Border>
                    </Grid>
                </Grid>
            </Grid>
            <!-- Plugins View -->
            <Grid x:Name="PluginsViewGrid" Grid.Row="1" Visibility="Collapsed">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="350"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                
                <!-- Plugin List -->
                <Border Grid.Column="0" Style="{StaticResource GlassBorder}" Margin="0,0,10,0">
                    <DockPanel>
                        <DockPanel DockPanel.Dock="Top" Margin="0,0,0,15">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="🔌" Foreground="#8b5cf6" FontSize="20" Margin="0,0,10,0"/>
                                <TextBlock Text="插件列表" Foreground="White" FontSize="18" FontWeight="SemiBold"/>
                            </StackPanel>
                            <Button Content="🔄" Click="RefreshPlugins" HorizontalAlignment="Right" Style="{StaticResource IconButton}" ToolTip="刷新"/>
                        </DockPanel>
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <StackPanel x:Name="PluginsContainer"/>
                        </ScrollViewer>
                    </DockPanel>
                </Border>
                
                <!-- Plugin Details & Editor Launch -->
                <Grid Grid.Column="1">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    
                    <!-- Godot Editor Launch Button -->
                    <Border Grid.Row="0" Style="{StaticResource GlassBorder}" Margin="0,0,0,15">
                        <DockPanel>
                            <StackPanel>
                                <TextBlock Text="🎮 Godot Editor" Foreground="White" FontSize="18" FontWeight="SemiBold"/>
                                <TextBlock Text="启动 Godot 编辑器打开当前项目" Foreground="#64748b" FontSize="12" Margin="0,5,0,0"/>
                            </StackPanel>
                            <Button x:Name="BtnOpenEditor" Content="🚀 启动编辑器" Click="OpenGodotEditor" 
                                    Style="{StaticResource PrimaryButtonStyle}" HorizontalAlignment="Right" 
                                    VerticalAlignment="Center" Padding="15,10"/>
                        </DockPanel>
                    </Border>
                    
                    <!-- Plugin Details -->
                    <Border Grid.Row="1" Style="{StaticResource GlassBorder}">
                        <DockPanel>
                            <DockPanel DockPanel.Dock="Top" Margin="0,0,0,15">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="📋" Foreground="#8b5cf6" FontSize="20" Margin="0,0,10,0"/>
                                    <TextBlock Text="插件详情" Foreground="White" FontSize="18" FontWeight="SemiBold"/>
                                </StackPanel>
                            </DockPanel>
                            <ScrollViewer VerticalScrollBarVisibility="Auto">
                                <StackPanel x:Name="PluginDetailsContainer"/>
                            </ScrollViewer>
                        </DockPanel>
                    </Border>
                </Grid>
            </Grid>
        </Grid>
    </Grid>
</Window>

