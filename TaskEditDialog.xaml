<Window x:Class="GamePrince.TaskEditDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="编辑任务" Height="650" Width="450"
        Background="#0f172a" WindowStartupLocation="CenterOwner"
        FontFamily="Segoe UI" Foreground="White">
    <Grid Margin="30">
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <TextBlock Text="任务标题" Foreground="#94a3b8" Margin="0,0,0,5"/>
                <TextBox x:Name="TitleInput" Background="#1e293b" Foreground="White" BorderThickness="0" Padding="10" Margin="0,0,0,20"/>

                <TextBlock Text="任务描述 (支持 Markdown)" Foreground="#94a3b8" Margin="0,0,0,5"/>
                <TextBox x:Name="DescriptionInput" Background="#1e293b" Foreground="White" BorderThickness="0" Padding="10" Margin="0,0,0,20" Height="100" TextWrapping="Wrap" AcceptsReturn="True" VerticalScrollBarVisibility="Auto"/>

                <TextBlock Text="分类" Foreground="#94a3b8" Margin="0,0,0,5"/>
                <ComboBox x:Name="CategoryInput" Background="#1e293b" Foreground="White" BorderThickness="0" Margin="0,0,0,20">
                    <ComboBoxItem Content="程序"/>
                    <ComboBoxItem Content="美术"/>
                    <ComboBoxItem Content="环境"/>
                    <ComboBoxItem Content="文档"/>
                </ComboBox>

                <TextBlock Text="里程碑" Foreground="#94a3b8" Margin="0,0,0,5"/>
                <ComboBox x:Name="MilestoneInput" Background="#1e293b" Foreground="White" BorderThickness="0" Margin="0,0,0,20" DisplayMemberPath="Title" SelectedValuePath="Id"/>

                <Grid Margin="0,0,0,20">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" Margin="0,0,10,0">
                        <TextBlock Text="紧急度" Foreground="#94a3b8" Margin="0,0,0,5"/>
                        <TextBox x:Name="UrgencyInput" Background="#1e293b" Foreground="White" BorderThickness="0" Padding="10"/>
                    </StackPanel>
                    <StackPanel Grid.Column="1" Margin="5,0,5,0">
                        <TextBlock Text="重要度" Foreground="#94a3b8" Margin="0,0,0,5"/>
                        <TextBox x:Name="ImportanceInput" Background="#1e293b" Foreground="White" BorderThickness="0" Padding="10"/>
                    </StackPanel>
                    <StackPanel Grid.Column="2" Margin="10,0,0,0">
                        <TextBlock Text="预计工时" Foreground="#94a3b8" Margin="0,0,0,5"/>
                        <TextBox x:Name="EstimateInput" Background="#1e293b" Foreground="White" BorderThickness="0" Padding="10"/>
                    </StackPanel>
                </Grid>

                <TextBlock Text="标签 (以逗号分隔)" Foreground="#94a3b8" Margin="0,0,0,5"/>
                <TextBox x:Name="TagsInput" Background="#1e293b" Foreground="White" BorderThickness="0" Padding="10" Margin="0,0,0,30"/>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="取消" Click="Cancel_Click" Background="Transparent" Foreground="#94a3b8" BorderThickness="0" Margin="0,0,20,0" Padding="10,5" Cursor="Hand"/>
                    <Button Content="保存" Click="Save_Click" Background="#8b5cf6" Foreground="White" BorderThickness="0" Padding="25,8" Cursor="Hand">
                        <Button.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="8"/>
                            </Style>
                        </Button.Resources>
                    </Button>
                </StackPanel>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Window>
