<Window x:Class="GamePrince.MilestoneEditDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="编辑里程碑" Height="400" Width="400"
        Background="#0f172a" WindowStartupLocation="CenterOwner"
        FontFamily="Segoe UI" Foreground="White" ResizeMode="NoResize">
    <Grid Margin="30">
        <StackPanel>
            <TextBlock Text="里程碑标题" Foreground="#94a3b8" Margin="0,0,0,5"/>
            <TextBox x:Name="TitleInput" Background="#1e293b" Foreground="White" BorderThickness="0" Padding="10" Margin="0,0,0,20"/>

            <TextBlock Text="版本号" Foreground="#94a3b8" Margin="0,0,0,5"/>
            <TextBox x:Name="VersionInput" Background="#1e293b" Foreground="White" BorderThickness="0" Padding="10" Margin="0,0,0,20"/>

            <TextBlock Text="描述" Foreground="#94a3b8" Margin="0,0,0,5"/>
            <TextBox x:Name="DescriptionInput" Background="#1e293b" Foreground="White" BorderThickness="0" Padding="10" Margin="0,0,0,20" Height="60" TextWrapping="Wrap" AcceptsReturn="True"/>

            <Grid Margin="0,0,0,20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" Margin="0,0,10,0">
                    <TextBlock Text="开始日期" Foreground="#94a3b8" Margin="0,0,0,5"/>
                    <TextBox x:Name="StartDateInput" Background="#1e293b" Foreground="White" BorderThickness="0" Padding="10"/>
                </StackPanel>
                <StackPanel Grid.Column="1" Margin="10,0,0,0">
                    <TextBlock Text="目标日期" Foreground="#94a3b8" Margin="0,0,0,5"/>
                    <TextBox x:Name="TargetDateInput" Background="#1e293b" Foreground="White" BorderThickness="0" Padding="10"/>
                </StackPanel>
            </Grid>

            <CheckBox x:Name="IsCompletedInput" Content="已完成" Foreground="White" Margin="0,0,0,30"/>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="取消" Click="Cancel_Click" Background="Transparent" Foreground="#94a3b8" BorderThickness="0" Margin="0,0,20,0" Padding="10,5" Cursor="Hand"/>
                <Button Content="保存" Click="Save_Click" Background="#8b5cf6" Foreground="White" BorderThickness="0" Padding="25,8" Cursor="Hand">
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="8"/>
                        </Style>
                    </Button.Resources>
                </Button>
            </StackPanel>
        </StackPanel>
    </Grid>
</Window>
